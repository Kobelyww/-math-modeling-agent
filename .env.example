

# ===== 必填 =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com

# 阿里云百练 Embedding（RAG 语义检索）
EMBEDDING_API_KEY=sk-your-bailian-api-key

# ===== LLM 可选配置 =====
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_TEMPERATURE=0.3
# DEEPSEEK_MAX_RETRIES=3

# 按角色微调温度（可选）
# DEEPSEEK_DATA_ENGINEER_TEMPERATURE=0.1
# DEEPSEEK_MODELER_TEMPERATURE=0.3
# DEEPSEEK_PROGRAMMER_TEMPERATURE=0.2
# DEEPSEEK_CODE_DEBUGGER_TEMPERATURE=0.1
# DEEPSEEK_WRITER_TEMPERATURE=0.4
# DEEPSEEK_REVIEWER_TEMPERATURE=0.2
# DEEPSEEK_SYNTHESIZER_TEMPERATURE=0.3

# ===== Redis Stack（记忆系统后端）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-secure
REDIS_DB=0